<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Group Decision Poll</title>

  <!-- Firebase SDKs (compat v10) -->
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>

  <style>
    /* ── Reset & Base ─────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:      #2563EB;
      --blue-dk:   #1D4ED8;
      --blue-lt:   #EFF6FF;
      --amber:     #F59E0B;
      --green:     #10B981;
      --red:       #EF4444;
      --grey-50:   #F9FAFB;
      --grey-100:  #F3F4F6;
      --grey-200:  #E5E7EB;
      --grey-400:  #9CA3AF;
      --grey-600:  #4B5563;
      --grey-800:  #1F2937;
      --gold:      #F59E0B;
      --silver:    #9CA3AF;
      --bronze:    #B45309;
      --radius:    12px;
      --shadow:    0 2px 12px rgba(0,0,0,0.10);
      --shadow-lg: 0 8px 32px rgba(0,0,0,0.14);
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #EFF6FF 0%, #F0FDF4 100%);
      min-height: 100vh;
      color: var(--grey-800);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 16px 60px;
    }

    /* ── Header ───────────────────────────────────────────── */
    header {
      width: 100%;
      max-width: 640px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--blue);
    }
    .logo svg { width: 32px; height: 32px; }
    #user-badge {
      font-size: 0.82rem;
      background: white;
      border: 1.5px solid var(--grey-200);
      border-radius: 20px;
      padding: 5px 14px;
      color: var(--grey-600);
      cursor: pointer;
      transition: border-color .2s;
    }
    #user-badge:hover { border-color: var(--blue); color: var(--blue); }
    #user-badge.hidden { display: none; }

    /* ── Card ─────────────────────────────────────────────── */
    .card {
      background: white;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 32px 28px;
      width: 100%;
      max-width: 640px;
    }
    .card h2 {
      font-size: 1.35rem;
      font-weight: 700;
      margin-bottom: 6px;
      color: var(--grey-800);
    }
    .card .subtitle {
      font-size: 0.9rem;
      color: var(--grey-600);
      margin-bottom: 24px;
    }

    /* ── Screens ──────────────────────────────────────────── */
    .screen { display: none; width: 100%; max-width: 640px; }
    .screen.active { display: block; }

    /* ── Form elements ────────────────────────────────────── */
    label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--grey-600);
      margin-bottom: 6px;
    }
    input[type="text"], input[type="password"], input[type="number"] {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid var(--grey-200);
      border-radius: 8px;
      font-size: 0.95rem;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      color: var(--grey-800);
      background: var(--grey-50);
    }
    input:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
      background: white;
    }

    /* ── Buttons ──────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      padding: 11px 22px;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: transform .12s, box-shadow .12s, background .15s;
    }
    .btn:active { transform: scale(0.97); }
    .btn-primary {
      background: var(--blue);
      color: white;
      box-shadow: 0 2px 8px rgba(37,99,235,0.28);
    }
    .btn-primary:hover { background: var(--blue-dk); }
    .btn-primary:disabled {
      background: var(--grey-400);
      box-shadow: none;
      cursor: not-allowed;
    }
    .btn-secondary {
      background: white;
      color: var(--blue);
      border: 1.5px solid var(--blue);
    }
    .btn-secondary:hover { background: var(--blue-lt); }
    .btn-danger {
      background: white;
      color: var(--red);
      border: 1.5px solid var(--red);
    }
    .btn-danger:hover { background: #FEF2F2; }
    .btn-full { width: 100%; }
    .btn-sm { padding: 7px 14px; font-size: 0.83rem; }

    /* ── Name Screen ──────────────────────────────────────── */
    #screen-name .card { text-align: center; }
    #screen-name .card h2 { font-size: 1.7rem; margin-bottom: 8px; }
    #screen-name .card .tagline {
      font-size: 1rem;
      color: var(--grey-600);
      margin-bottom: 32px;
    }
    .name-form { text-align: left; }
    .name-form .field { margin-bottom: 16px; }
    .name-actions {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 8px;
    }
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--grey-400);
      font-size: 0.82rem;
      margin: 4px 0;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--grey-200);
    }

    /* ── Admin Screen ─────────────────────────────────────── */
    .admin-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .admin-badge {
      background: var(--amber);
      color: white;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .options-list { margin-bottom: 16px; }
    .option-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }
    .option-row .opt-num {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--grey-400);
      width: 20px;
      text-align: right;
      flex-shrink: 0;
    }
    .option-row input { flex: 1; }
    .option-row .btn-remove {
      background: none;
      border: none;
      color: var(--grey-400);
      cursor: pointer;
      padding: 4px 6px;
      border-radius: 6px;
      font-size: 1.1rem;
      transition: color .15s, background .15s;
      line-height: 1;
    }
    .option-row .btn-remove:hover { color: var(--red); background: #FEF2F2; }
    .add-option-row {
      margin-bottom: 24px;
    }
    .admin-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.82rem;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 16px;
    }
    .status-pill.active { background: #D1FAE5; color: #065F46; }
    .status-pill.inactive { background: var(--grey-100); color: var(--grey-600); }
    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
    }
    .status-pill.active .status-dot { background: var(--green); }
    .status-pill.inactive .status-dot { background: var(--grey-400); }

    /* ── Voter Info box ───────────────────────────────────── */
    .voter-info {
      background: var(--blue-lt);
      border: 1.5px solid #BFDBFE;
      border-radius: 10px;
      padding: 14px 18px;
      margin-bottom: 22px;
      font-size: 0.9rem;
      color: var(--blue);
    }
    .voter-info strong { font-weight: 700; }

    /* ── Rank selector ────────────────────────────────────── */
    .rank-slots {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 22px;
    }
    .rank-slot {
      background: var(--grey-50);
      border: 2px dashed var(--grey-200);
      border-radius: 10px;
      padding: 12px 8px;
      text-align: center;
      min-height: 72px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      transition: border-color .2s, background .2s;
    }
    .rank-slot.filled {
      border-style: solid;
      background: white;
    }
    .rank-slot.rank-1.filled { border-color: var(--gold); }
    .rank-slot.rank-2.filled { border-color: var(--silver); }
    .rank-slot.rank-3.filled { border-color: var(--bronze); }
    .rank-medal {
      font-size: 1.4rem;
      line-height: 1;
    }
    .rank-pts {
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--grey-400);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .rank-slot.rank-1 .rank-pts { color: var(--gold); }
    .rank-slot.rank-2 .rank-pts { color: var(--silver); }
    .rank-slot.rank-3 .rank-pts { color: var(--bronze); }
    .rank-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--grey-600);
    }
    .rank-slot.filled .rank-label { color: var(--grey-800); }
    .rank-empty-text {
      font-size: 0.78rem;
      color: var(--grey-400);
    }

    /* ── Option Cards (voting) ────────────────────────────── */
    .options-grid {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 24px;
    }
    .opt-card {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 13px 16px;
      background: white;
      border: 2px solid var(--grey-200);
      border-radius: 10px;
      cursor: pointer;
      transition: border-color .18s, box-shadow .18s, background .18s;
      user-select: none;
    }
    .opt-card:hover:not(.disabled) {
      border-color: var(--blue);
      box-shadow: 0 2px 10px rgba(37,99,235,0.10);
    }
    .opt-card.selected-1 { border-color: var(--gold); background: #FFFBEB; }
    .opt-card.selected-2 { border-color: var(--silver); background: #F9FAFB; }
    .opt-card.selected-3 { border-color: var(--bronze); background: #FEF3C7; }
    .opt-card.disabled { cursor: not-allowed; opacity: 0.5; }
    .opt-rank-badge {
      width: 30px; height: 30px;
      border-radius: 50%;
      font-size: 0.78rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background .18s, color .18s;
    }
    .unselected-badge {
      background: var(--grey-100);
      color: var(--grey-400);
    }
    .badge-1 { background: var(--gold); color: white; }
    .badge-2 { background: var(--silver); color: white; }
    .badge-3 { background: var(--bronze); color: white; }
    .opt-card-text { font-size: 0.95rem; font-weight: 500; flex: 1; }

    /* ── Results ──────────────────────────────────────────── */
    .results-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
    .result-row {
      background: white;
      border-radius: 10px;
      padding: 14px 16px;
      border: 1.5px solid var(--grey-200);
      transition: box-shadow .2s;
    }
    .result-row.rank-1 { border-color: var(--gold); box-shadow: 0 2px 10px rgba(245,158,11,0.15); }
    .result-row.rank-2 { border-color: var(--silver); }
    .result-row.rank-3 { border-color: var(--bronze); }
    .result-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .result-pos {
      font-size: 1.3rem;
      width: 32px;
      text-align: center;
      flex-shrink: 0;
    }
    .result-name { font-weight: 600; font-size: 0.95rem; flex: 1; }
    .result-pts {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--blue);
    }
    .result-pts span { font-size: 0.75rem; font-weight: 500; color: var(--grey-400); }
    .result-bar-bg {
      background: var(--grey-100);
      border-radius: 6px;
      height: 8px;
      overflow: hidden;
    }
    .result-bar {
      height: 8px;
      border-radius: 6px;
      background: var(--blue);
      transition: width 0.6s cubic-bezier(.4,0,.2,1);
    }
    .result-row.rank-1 .result-bar { background: var(--gold); }
    .result-row.rank-2 .result-bar { background: var(--silver); }
    .result-row.rank-3 .result-bar { background: var(--bronze); }

    /* ── Voter roster ─────────────────────────────────────── */
    .voter-roster {
      margin-top: 8px;
      padding-top: 20px;
      border-top: 1.5px solid var(--grey-100);
    }
    .voter-roster h4 {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--grey-600);
      margin-bottom: 10px;
    }
    .voter-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .voter-chip {
      background: var(--green);
      color: white;
      border-radius: 20px;
      padding: 3px 12px;
      font-size: 0.8rem;
      font-weight: 500;
    }

    /* ── Waiting screen ───────────────────────────────────── */
    .waiting-icon {
      font-size: 3.5rem;
      text-align: center;
      margin-bottom: 16px;
    }

    /* ── Toast ────────────────────────────────────────────── */
    #toast {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--grey-800);
      color: white;
      padding: 12px 22px;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      box-shadow: var(--shadow-lg);
      z-index: 999;
      transition: transform .3s cubic-bezier(.4,0,.2,1);
      white-space: nowrap;
    }
    #toast.show { transform: translateX(-50%) translateY(0); }
    #toast.success { background: var(--green); }
    #toast.error { background: var(--red); }

    /* ── Modal (admin pin) ────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 100;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: white;
      border-radius: var(--radius);
      padding: 28px 24px;
      width: 100%;
      max-width: 360px;
      box-shadow: var(--shadow-lg);
    }
    .modal h3 { font-size: 1.15rem; margin-bottom: 8px; }
    .modal p { font-size: 0.88rem; color: var(--grey-600); margin-bottom: 18px; }
    .modal-actions { display: flex; gap: 10px; margin-top: 16px; }
    .modal-actions .btn { flex: 1; }

    /* ── Misc ─────────────────────────────────────────────── */
    .mt8 { margin-top: 8px; }
    .mt16 { margin-top: 16px; }
    .mt24 { margin-top: 24px; }
    .gap8 { gap: 8px; }
    .flex { display: flex; }
    .flex-col { flex-direction: column; }
    .voted-banner {
      background: #D1FAE5;
      border: 1.5px solid #6EE7B7;
      color: #065F46;
      border-radius: 10px;
      padding: 14px 18px;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .section-title {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--grey-400);
      margin-bottom: 12px;
    }

    @media (max-width: 480px) {
      .card { padding: 22px 16px; }
      .admin-actions { flex-direction: column; }
      .rank-slots { gap: 6px; }
    }
  </style>
</head>
<body>

  <!-- ── Header ─────────────────────────────────────────── -->
  <header>
    <div class="logo">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="#2563EB"/>
        <rect x="7" y="20" width="4" height="7" rx="2" fill="white"/>
        <rect x="14" y="14" width="4" height="13" rx="2" fill="white" opacity="0.8"/>
        <rect x="21" y="8" width="4" height="19" rx="2" fill="white" opacity="0.6"/>
        <circle cx="9" cy="18" r="2.5" fill="#F59E0B"/>
        <circle cx="16" cy="12" r="2.5" fill="#F59E0B"/>
        <circle cx="23" cy="6" r="2.5" fill="#F59E0B"/>
      </svg>
      GroupPoll
    </div>
    <div id="user-badge" class="hidden" onclick="handleLogout()">👤 <span id="user-badge-name"></span> &nbsp;·&nbsp; Change</div>
  </header>

  <!-- ═══════════════ SCREEN: NAME ENTRY ═══════════════════ -->
  <div id="screen-name" class="screen active">
    <div class="card">
      <div style="text-align:center; font-size:2.8rem; margin-bottom:12px;">🗳️</div>
      <h2 style="text-align:center; font-size:1.6rem;">Welcome to GroupPoll</h2>
      <p class="tagline" style="text-align:center; margin-bottom:28px;">Rank your top 3 choices to help the group decide.</p>

      <div class="name-form">
        <div class="field">
          <label for="input-name">Your name</label>
          <input type="text" id="input-name" placeholder="e.g. Jacob Smith" autocomplete="off" />
        </div>
        <div class="name-actions">
          <button class="btn btn-primary btn-full" onclick="handleNameSubmit()">
            Join &amp; Vote →
          </button>
          <div class="divider">or</div>
          <button class="btn btn-secondary btn-full" onclick="openAdminModal()">
            🔧 Admin Login
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ SCREEN: ADMIN ════════════════════════ -->
  <div id="screen-admin" class="screen">
    <div class="card">
      <div class="admin-header">
        <h2 style="margin-bottom:0">Poll Manager</h2>
        <span class="admin-badge">Admin</span>
      </div>
      <p class="subtitle">Create or update the active poll. Changes are live immediately.</p>

      <div id="admin-poll-status"></div>

      <div class="field" style="margin-bottom:16px;">
        <label for="admin-title">Poll title / question</label>
        <input type="text" id="admin-title" placeholder="e.g. Where should we go for the team lunch?" />
      </div>

      <div class="section-title">Options (min 3, max 10)</div>
      <div class="options-list" id="admin-options-list">
        <!-- rows injected by JS -->
      </div>
      <div class="add-option-row">
        <button class="btn btn-secondary btn-sm" id="btn-add-option" onclick="addOptionRow()">+ Add Option</button>
      </div>

      <div class="admin-actions">
        <button class="btn btn-primary" onclick="publishPoll()" id="btn-publish">🚀 Publish Poll</button>
        <button class="btn btn-danger" onclick="resetPoll()" id="btn-reset">🗑 Reset &amp; Clear</button>
        <button class="btn btn-secondary" onclick="goToResults()">📊 View Results</button>
      </div>

      <div id="admin-voter-list" style="margin-top:20px;"></div>
    </div>
  </div>

  <!-- ═══════════════ SCREEN: VOTE ═════════════════════════ -->
  <div id="screen-vote" class="screen">
    <div class="card">
      <h2 id="vote-poll-title">Loading poll...</h2>
      <p class="subtitle" id="vote
